# Copy to %LOCALAPPDATA%\3dsmax-mcp\.env and fill in a key.
# The native bridge loads this file at plugin start and on /reload.
# First non-empty key wins: OPENROUTER_API_KEY → LLM_API_KEY → OPENAI_API_KEY.
# Real environment variables (set via `setx` or shell) override anything here.

OPENROUTER_API_KEY=
# LLM_API_KEY=
# OPENAI_API_KEY=
